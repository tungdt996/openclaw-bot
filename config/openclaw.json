{
  // OpenClaw K8s Operations Bot Configuration
  // JSON5 format - comments and trailing commas are allowed

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      userTimezone: "Asia/Ho_Chi_Minh",
      model: {
        primary: "openai/gpt-4.1-nano",
        fallbacks: ["openai/gpt-4o-mini"]
      },
      thinkingDefault: "low",
      timeoutSeconds: 300,
      maxConcurrent: 2
    },
    list: [
      {
        id: "default",
        identity: {
          name: "K8s-Ops-Bot",
          theme: "senior SRE assistant specialized in Kubernetes operations, monitoring, and troubleshooting",
          emoji: "⎈"
        }
      }
    ]
  },

  channels: {
    telegram: {
      enabled: true,
      // Replace with your actual bot token from @BotFather
      botToken: "${TELEGRAM_BOT_TOKEN}",
      // Replace with your Telegram user ID(s) - get from @userinfobot
      dmPolicy: "allowlist",
      allowFrom: ["${TELEGRAM_ALLOWED_USERS}"],
      groupPolicy: "allowlist",
      groupAllowFrom: ["${TELEGRAM_ALLOWED_USERS}", "${TELEGRAM_GROUP_CHAT_ID}"],
      groups: {
        "*": { requireMention: true }
      }
    }
  },

  tools: {
    allow: ["exec", "read", "write", "edit"],
    elevated: {
      enabled: true
    }
  },

  session: {
    scope: "per-sender",
    reset: {
      mode: "idle",
      idleMinutes: 60
    },
    resetTriggers: ["/new", "/reset"]
  },

  logging: {
    level: "info",
    consoleLevel: "info",
    consoleStyle: "pretty",
    redactSensitive: "tools"
  },

  gateway: {
    mode: "local",
    port: 18789,
    bind: "lan",
    auth: {
      token: "${OPENCLAW_AUTH_TOKEN}"
    },
    controlUi: {
      enabled: true,
      basePath: "/",
      allowedOrigins: [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },

  // Kubernetes MCP integration is handled via mcporter + custom skill.
  // Config: config/mcporter.json  (MCP server connection)
  // Skill:  skills/kubernetes-ops/ (teaches agent to use mcporter CLI)
}
