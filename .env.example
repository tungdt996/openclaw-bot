# =============================================================================
# OpenClaw K8s Ops Bot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# --- OpenAI API ---
# Get your API key from: https://platform.openai.com/api-keys
# Requires a paid account with API access (separate from ChatGPT Plus)
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram: https://t.me/BotFather
# Send /newbot, follow instructions, copy the token
TELEGRAM_BOT_TOKEN=7841293847:AAHzxKqPm8vXYjNwT3fLd9GcBuE5iOvRkQs

# Telegram user IDs allowed to interact with the bot.
# Get your user ID from @userinfobot on Telegram: https://t.me/userinfobot
# For multiple users, update the allowFrom array in config/openclaw.json directly
TELEGRAM_ALLOWED_USERS=123456789

# --- Telegram Alert Group ---
# Group chat ID where K8s alerts will be forwarded
# How to get: add bot to group → send a message → call
# https://api.telegram.org/bot<TOKEN>/getUpdates → find chat.id (negative number)
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# Bot username (without @) for @mention in alert messages
BOT_USERNAME=openclaw_k8s_bot

# --- OpenClaw Gateway ---
# Fixed auth token for accessing the gateway UI
# Generate your own: openssl rand -hex 32
OPENCLAW_AUTH_TOKEN=your-secret-token-here
